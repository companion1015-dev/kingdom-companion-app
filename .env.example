# ============================================================
# KINGDOM COMPANION — ENVIRONMENT VARIABLES
# Copy to .env.local and fill in values
# NEVER commit .env.local to source control
# ============================================================

# ─── DATABASE (Supabase) ─────────────────────────────────────
# From: Supabase Dashboard → Settings → Database → Connection String
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── SUPABASE ────────────────────────────────────────────────
# From: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── AUTH ────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET="your-256-bit-secret-minimum-32-chars"
JWT_REFRESH_SECRET="your-separate-refresh-token-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── APP ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── EMAIL (Resend) ──────────────────────────────────────────
# From: resend.com → API Keys
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="The Kingdom Companion <noreply@yourdomain.com>"

# ─── AI (Anthropic) ──────────────────────────────────────────
# From: console.anthropic.com → API Keys
ANTHROPIC_API_KEY="sk-ant-your-key-here"
AI_MODEL="claude-sonnet-4-6"

# ─── BIBLE.COM API ───────────────────────────────────────────
# Request from: developer.youversion.com
BIBLE_API_KEY="your-bible-api-key"
BIBLE_API_BASE_URL="https://api.scripture.api.bible/v1"

# ─── SEARCH (Algolia) ────────────────────────────────────────
# From: algolia.com → Dashboard → API Keys
NEXT_PUBLIC_ALGOLIA_APP_ID="your-app-id"
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY="your-search-only-key"
ALGOLIA_ADMIN_KEY="your-admin-key"

# ─── PAYMENTS (Stripe) ───────────────────────────────────────
# From: stripe.com → Developers → API Keys
# DONATIONS ONLY — no feature paywalls (Constitution §4)
STRIPE_SECRET_KEY="sk_test_your-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-key"

# ─── STORAGE (Cloudflare R2) ─────────────────────────────────
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="kingdom-companion-assets"
NEXT_PUBLIC_R2_PUBLIC_URL="https://assets.yourdomain.com"

# ─── MONITORING (Sentry) ─────────────────────────────────────
SENTRY_DSN="https://your-sentry-dsn"
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn"

# ─── ANALYTICS (Plausible — privacy first) ───────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="yourdomain.com"

# ─── RATE LIMITING ───────────────────────────────────────────
RATE_LIMIT_AUTH_REQUESTS="10"
RATE_LIMIT_AUTH_WINDOW_MS="900000"
RATE_LIMIT_AI_REQUESTS="30"
RATE_LIMIT_AI_WINDOW_MS="3600000"
